# Required: Telegram Bot Token (get from @BotFather)
BOT_TOKEN=

# Required: Telegram user IDs for admin commands (comma-separated)
ADMIN_IDS=

# Optional: Database path (SQLite fallback when DATABASE_URL is not set)
DATABASE_PATH=database/bot.db

# Optional: PostgreSQL connection string (for persistence on Render)
# Set this to use PostgreSQL instead of SQLite
DATABASE_URL=

# Optional: Encryption key for GitHub tokens.
# If not set, BOT_TOKEN is used as fallback.
# IMPORTANT: Set a fixed value here to avoid data loss if BOT_TOKEN changes.
ENCRYPTION_KEY=

# Optional: Your Render public URL (for keep-alive self-pings)
# e.g. https://your-app.onrender.com
RENDER_EXTERNAL_URL=

# Optional: GitHub Storage Repository for database persistence
# The bot will back up its SQLite database to this private repo
# so that it survives Render restarts/redeploys.
# Create a private repo, then set the URL and a token with repo access.
# STORAGE_REPO_URL=https://github.com/yourusername/gitsync-bot-storage.git
# STORAGE_REPO_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional settings
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=2048
MAX_ZIP_ENTRIES=20000
CONNECT_TIMEOUT=60.0
READ_TIMEOUT=60.0
WRITE_TIMEOUT=60.0
